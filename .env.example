# Database (SQLite - path relative to project root)
DATABASE_URL="file:./src/db/soberai.db"

# Ollama (local)
OLLAMA_ENDPOINT=http://localhost:11434

# OpenAI / OpenAI-compatible (optional - e.g. NVIDIA NIM uses the openai provider
# with a custom endpoint, configured via the Settings UI)
# OPENAI_API_KEY=your-openai-or-nvidia-api-key

# Server
NODE_ENV=development
PORT=3000

# Frontend
VITE_API_URL=http://localhost:3000

# --- Deployment hardening (Phase 7) ---
# CORS allowlist for split-origin cloud deploys (comma-separated). Unset = wildcard
# (local/Electron same-origin). Example: CORS_ORIGIN=https://app.example.com
# CORS_ORIGIN=

# Per-IP audit request limit per minute (default 30). Tunable for capacity.
# AUDIT_RATE_LIMIT=30

# SSRF guard: block audit targets resolving to private/loopback/link-local IPs.
# Default ON (1). Set to 0 for local dev that audits internal/staging URLs.
# SSRF_BLOCK_PRIVATE=1

# Per-browser report isolation via an ephemeral owner-token cookie. Default: active
# in production, inactive in development (reports stay global/local). Set OWNER_TOKEN_REQUIRED=1
# to force it on in any environment.
# OWNER_TOKEN_REQUIRED=

