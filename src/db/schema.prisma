datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

model Report {
  id              String    @id @default(cuid())
  url             String

  // Audit results
  overallScore    Int
  grade           String

  // Category scores
  ssrScore                Int
  schemaScore             Int
  semanticScore           Int
  contentScore            Int
  machineReadabilityScore Int  @default(0)

  // Metadata
  detectedIndustry String
  duration        Int       // milliseconds

  // Full results (JSON stored as String for SQLite)
  auditResults    String
  recommendations String?

  // Ephemeral owner token for per-browser report isolation (invariant G).
  // Nullable: null = legacy/global visibility (desktop/local single-user unaffected).
  ownerToken      String?

  // Timestamps
  createdAt       DateTime  @default(now())

  @@index([url])
  @@index([createdAt])
  @@index([ownerToken])
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
