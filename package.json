{
  "name": "sober-ai-optimizer",
  "version": "0.2.0",
  "description": "AI Agent Website Optimizer - MVP with Authentication",
  "main": "src/api/server.js",
  "scripts": {
    "start": "node src/api/server.js",
    "dev": "nodemon src/api/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.js'",
    "docker:build": "docker-compose -f docker-compose.dev.yml build",
    "docker:up": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "ollama:pull": "docker exec sober-ollama-dev ollama pull qwen3:4b",
    "db:generate": "prisma generate --schema=backend/src/db/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=backend/src/db/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=backend/src/db/schema.prisma",
    "db:studio": "prisma studio --schema=backend/src/db/schema.prisma",
    "db:seed": "node backend/src/db/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "@vitejs/plugin-react": "^4.7.0",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "bull": "^4.11.5",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "playwright": "^1.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "redis": "^5.8.2",
    "uuid": "^9.0.1",
    "vite": "^6.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "prisma": "^6.16.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
